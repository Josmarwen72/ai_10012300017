# LLM Provider Configuration
# Options: auto, openai, groq, local
ACITY_LLM_PROVIDER=groq

# OpenAI Configuration (optional)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
ACITY_OPENAI_MODEL=gpt-4o-mini

# Groq Configuration (recommended)
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
ACITY_GROQ_MODEL=llama-3.1-8b-instant

# Local LLM Configuration (fallback when no API keys are set)
ACITY_LOCAL_LLM_MODEL=google/flan-t5-base
ACITY_LOCAL_LLM_MAX_NEW_TOKENS=220

# Data Configuration
# Leave empty to use default data directory
ACITY_DATA_DIR=
ACITY_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Retrieval Configuration
ACITY_TOP_K=8
ACITY_HYBRID_ALPHA=0.65
ACITY_MAX_CONTEXT_CHARS=6000
